{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(dotnet build:*)",
      "Bash(dotnet restore:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "PowerShell(dotnet build *)",
      "PowerShell(dotnet restore *)",
      "PowerShell(npm run lint*)",
      "PowerShell(npm run build*)",
      "PowerShell(npx expo lint*)",
      "PowerShell(Set-Location *)",
      "Read"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Projects/Epitcore/maraebiz-platform/.claude/hooks/verify.ps1"
          }
        ]
      }
    ]
  }
}
